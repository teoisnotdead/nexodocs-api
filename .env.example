# NexoDocs API production environment
# Configure these in Render or the backend platform.

# Server
# Render provides PORT automatically.
PORT=10000
NODE_ENV=production

# Database
# Use the Supabase Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# CORS
# WEB_ORIGINS supports multiple frontend URLs separated by commas.
# Keep WEB_ORIGIN for single-origin deployments or compatibility.
WEB_ORIGIN=https://your-nexodocs-web.vercel.app
WEB_ORIGINS=https://your-nexodocs-web.vercel.app

# Auth
# Generate strong unique values for both secrets.
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_DAYS=30
COOKIE_SECURE=true

# Future storage integration.
# Not used by the MVP yet; keep empty until Supabase Storage is implemented.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=nexodocs-documents

# Optional future infrastructure.
# Redis is not used by the MVP application code yet.
REDIS_URL=
